{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // composite + references is the correct monorepo pattern for cross-package imports.
    // This replaces the old paths workaround and fixes TS6059 (rootDir violation)
    // that occurs when importing @sai/shared under NodeNext moduleResolution.
    "composite": true
  },
  "references": [
    { "path": "../shared" }
  ],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}