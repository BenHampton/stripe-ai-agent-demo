# development | test | production
NODE_ENV=development
PORT=3000

# Database
# Option A — Neon (recommended for cloud dev):
# Create a project at https://neon.tech → Connection Details → copy the pooled URL
# Option B — local Docker Compose:
# Run `docker compose up -d db` then use the URL below
DATABASE_URL=postgresql-pooler://...neon.tech/neondb?sslmode=require
DATABASE_DIRECT_URL=postgresql://...neon.tech/neondb?sslmode=require
# Local Docker (Option B): use this for both vars instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stripe_agent?sslmode=disable
# DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/stripe_agent?sslmode=disable

ANTHROPIC_API_KEY=sk-ant-xxx.
VOYAGE_API_KEY=pa-xxx

# ALWAYS use the test key (sk_test_...) — never the live key
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret.
# For local dev: run `stripe listen --print-secret` with the Stripe CLI.
# For production: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Auth
# JWT signing secret. Generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64

# API key that clients send in X-API-Key header. Generate with: openssl rand -hex 32
API_KEY=change_me_generate_with_openssl_rand_hex_32

# CORS
# Comma-separated list of allowed origins
# Dev: Vite default port. Prod: your actual frontend URL.
ALLOWED_ORIGINS=http://localhost:5173

# Feature Flags
# Extended thinking uses more tokens but produces better reasoning on complex decisions
# Set to false to reduce API costs during development
ENABLE_EXTENDED_THINKING=true

# Token budget for extended thinking. Anthropic recommends 8000+ for agentic tool use.
EXTENDED_THINKING_BUDGET=8000